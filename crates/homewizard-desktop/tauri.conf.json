{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HWTray",
  "identifier": "com.homewizard-unofficial.desktop",
  "version": "0.1.2",
  "build": {
    "beforeBuildCommand": "mise run build:front",
    "beforeDevCommand": "mise run dev:front",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:"
    },
    "windows": [],
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/1024x1024.png",
      "icons/icon.png"
    ],
    "targets": ["dmg"],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
